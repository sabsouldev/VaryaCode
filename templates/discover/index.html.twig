{% extends 'base.html.twig' %}

{% block title %}Quel plan pour moi ? — VaryaCode{% endblock %}
{% block meta_description %}Répondez à 4 questions simples pour découvrir la formule VaryaCode adaptée à votre activité.{% endblock %}

{% block body %}
<div class="pt-16">
    <section class="py-16 bg-vc-bg min-h-[80vh] flex items-center">
        <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 w-full">

            {# Progress bar #}
            <div class="mb-10">
                <div class="flex justify-between text-sm text-vc-text-muted mb-2">
                    <span>Question <span id="current-step">1</span> sur 4</span>
                    <span id="progress-pct">25%</span>
                </div>
                <div class="w-full bg-slate-200 rounded-full h-2">
                    <div id="progress-bar" class="bg-gradient-to-r from-vc-blue to-vc-blue-sky h-2 rounded-full transition-all duration-300" style="width: 25%"></div>
                </div>
            </div>

            <form id="discover-form" action="{{ path('app_decouvrir_submit') }}" method="POST">

                {# STEP 1 — Qui êtes-vous ? #}
                <div class="discover-step" data-step="1">
                    <h1 class="font-heading text-3xl font-bold text-vc-text mb-8">Qui êtes-vous ?</h1>
                    <div class="space-y-3">
                        {% set profiles = [
                            { value: 'artisan', label: 'Artisan / Indépendant' },
                            { value: 'therapeute', label: 'Thérapeute / Praticien' },
                            { value: 'association', label: 'Association loi 1901' },
                            { value: 'commercant', label: 'Commerçant local' },
                            { value: 'autre', label: 'Autre' }
                        ] %}
                        {% for p in profiles %}
                        <label class="discover-option block cursor-pointer">
                            <input type="radio" name="profile" value="{{ p.value }}" class="hidden peer" required>
                            <div class="card-v2 !p-4 peer-checked:border-vc-blue peer-checked:bg-blue-50 transition-all">
                                <span class="text-vc-text font-medium">{{ p.label }}</span>
                            </div>
                        </label>
                        {% endfor %}
                    </div>
                </div>

                {# STEP 2 — Site existant ? #}
                <div class="discover-step hidden" data-step="2">
                    <h1 class="font-heading text-3xl font-bold text-vc-text mb-8">Avez-vous déjà un site web ?</h1>
                    <div class="space-y-3">
                        {% set sites = [
                            { value: 'non', label: "Non, c'est mon premier site" },
                            { value: 'oui_refaire', label: 'Oui, mais il ne me convient plus' },
                            { value: 'oui_remplacer', label: 'Oui, je veux le refaire' }
                        ] %}
                        {% for s in sites %}
                        <label class="discover-option block cursor-pointer">
                            <input type="radio" name="existing_site" value="{{ s.value }}" class="hidden peer" required>
                            <div class="card-v2 !p-4 peer-checked:border-vc-blue peer-checked:bg-blue-50 transition-all">
                                <span class="text-vc-text font-medium">{{ s.label }}</span>
                            </div>
                        </label>
                        {% endfor %}
                    </div>
                </div>

                {# STEP 3 — Besoins (multi-select) #}
                <div class="discover-step hidden" data-step="3">
                    <h1 class="font-heading text-3xl font-bold text-vc-text mb-2">De quoi avez-vous besoin ?</h1>
                    <p class="text-vc-text-muted mb-8">Sélectionnez tout ce qui vous concerne</p>
                    <div class="space-y-3">
                        {% set needs = [
                            { value: 'google', label: 'Être trouvé sur Google' },
                            { value: 'reservation', label: 'Permettre la réservation en ligne' },
                            { value: 'services', label: 'Afficher mes services et tarifs' },
                            { value: 'blog', label: 'Publier des actualités / un blog' },
                            { value: 'avis', label: 'Recueillir des avis clients' },
                            { value: 'fidelisation', label: 'Fidéliser mes clients' }
                        ] %}
                        {% for n in needs %}
                        <label class="discover-option block cursor-pointer">
                            <input type="checkbox" name="needs[]" value="{{ n.value }}" class="hidden peer">
                            <div class="card-v2 !p-4 peer-checked:border-vc-blue peer-checked:bg-blue-50 transition-all flex items-center gap-3">
                                <div class="w-5 h-5 rounded border-2 border-slate-300 flex items-center justify-center flex-shrink-0 peer-checked:bg-vc-blue peer-checked:border-vc-blue">
                                    <svg class="w-3 h-3 text-white hidden" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                                </div>
                                <span class="text-vc-text font-medium">{{ n.label }}</span>
                            </div>
                        </label>
                        {% endfor %}
                    </div>
                </div>

                {# STEP 4 — Budget #}
                <div class="discover-step hidden" data-step="4">
                    <h1 class="font-heading text-3xl font-bold text-vc-text mb-8">Quel est votre budget mensuel ?</h1>
                    <div class="space-y-3">
                        {% set budgets = [
                            { value: 'moins40', label: 'Moins de 40 €/mois' },
                            { value: '40-60', label: '40 – 60 €/mois' },
                            { value: 'plus60', label: 'Plus de 60 €/mois' },
                            { value: 'oneshot', label: 'Je préfère payer en une fois' }
                        ] %}
                        {% for b in budgets %}
                        <label class="discover-option block cursor-pointer">
                            <input type="radio" name="budget" value="{{ b.value }}" class="hidden peer" required>
                            <div class="card-v2 !p-4 peer-checked:border-vc-blue peer-checked:bg-blue-50 transition-all">
                                <span class="text-vc-text font-medium">{{ b.label }}</span>
                            </div>
                        </label>
                        {% endfor %}
                    </div>
                </div>

                {# Navigation buttons #}
                <div class="flex justify-between mt-10">
                    <button type="button" id="btn-prev" class="hidden text-vc-text-muted hover:text-vc-text font-medium transition-colors">&larr; Précédent</button>
                    <div class="ml-auto">
                        <button type="button" id="btn-next" class="btn-primary !py-3 !px-8">Suivant &rarr;</button>
                        <button type="submit" id="btn-submit" class="hidden btn-primary !py-3 !px-8">Voir mon résultat &rarr;</button>
                    </div>
                </div>
            </form>

        </div>
    </section>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('discover') }}
{% endblock %}
