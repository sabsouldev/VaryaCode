{% extends 'base.html.twig' %}

{% block title %}VaryaCode — Sites web pour artisans, associations et indépendants{% endblock %}
{% block meta_description %}VaryaCode, développeuse web en Dordogne. Sites vitrines professionnels dès 35 €/mois. Artisans, associations, indépendants : existez en ligne simplement.{% endblock %}

{% block body %}
<div class="pt-16">

    {# ===== SECTION 1 — HERO (fond sombre) ===== #}
    <section class="min-h-[90vh] flex items-center relative overflow-hidden bg-vc-dark">
        <div class="absolute inset-0 bg-gradient-to-br from-vc-dark via-vc-dark-alt to-vc-dark opacity-80"></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20">
            <div class="max-w-3xl">
                <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-white" data-animate>
                    Des solutions web simples et accessibles pour les petites structures locales
                </h1>
                <p class="text-slate-300 text-lg sm:text-xl leading-relaxed mb-10" data-animate data-animate-delay="100">
                    Artisans, associations, indépendants&nbsp;: vous méritez une présence en ligne professionnelle, sans complexité ni budget démesuré.
                </p>
                <div class="flex flex-col sm:flex-row gap-4" data-animate data-animate-delay="200">
                    <a href="{{ path('app_decouvrir') }}" class="btn-primary text-center">Quel plan pour moi&nbsp;?</a>
                    <a href="#offres" class="inline-block px-8 py-4 rounded-xl font-heading font-semibold text-lg text-slate-300 border border-slate-600 hover:border-slate-400 hover:text-white transition-all text-center">Découvrir les offres</a>
                </div>
            </div>
        </div>
    </section>

    {# ===== SECTION 2 — PROBLÈME (fond clair) ===== #}
    <section class="py-20 bg-vc-bg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="font-heading text-3xl sm:text-4xl font-bold text-center mb-16 text-vc-text" data-animate>
                Pourquoi c'est si compliqué d'avoir un bon site&nbsp;?
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                <div class="card-v2" data-animate data-animate-delay="100">
                    <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center mb-5">
                        <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <h3 class="font-heading text-xl font-semibold mb-3 text-vc-text">Les agences sont trop chères</h3>
                    <p class="text-vc-text-light">Des devis à 3&nbsp;000, 5&nbsp;000&nbsp;€… pour une simple vitrine. Quand on est une petite structure, ce n'est pas réaliste.</p>
                </div>
                <div class="card-v2" data-animate data-animate-delay="200">
                    <div class="w-12 h-12 rounded-xl bg-orange-50 flex items-center justify-center mb-5">
                        <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <h3 class="font-heading text-xl font-semibold mb-3 text-vc-text">Les outils en ligne sont trop complexes</h3>
                    <p class="text-vc-text-light">Wix, WordPress tout seul, des heures perdues à bidouiller… et un résultat qui ne vous ressemble pas.</p>
                </div>
                <div class="card-v2" data-animate data-animate-delay="300">
                    <div class="w-12 h-12 rounded-xl bg-yellow-50 flex items-center justify-center mb-5">
                        <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </div>
                    <h3 class="font-heading text-xl font-semibold mb-3 text-vc-text">L'accompagnement humain manque</h3>
                    <p class="text-vc-text-light">Pas d'interlocuteur, pas d'explication, un site livré et puis plus rien.</p>
                </div>
            </div>
            <div class="text-center bg-gradient-to-r from-blue-50 to-cyan-50 rounded-2xl p-8 border border-vc-blue/10" data-animate>
                <p class="font-heading text-xl font-semibold text-vc-blue mb-2">VaryaCode, c'est l'inverse.</p>
                <p class="text-vc-text-light">Un tarif clair dès 35&nbsp;€/mois, un site construit par une vraie développeuse, et un accompagnement du début à la fin.</p>
            </div>
        </div>
    </section>

    {# ===== SECTION 3 — QUI JE SUIS (fond blanc) ===== #}
    <section class="py-20 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row items-center gap-12" data-animate>
               <img src="{{ asset('img/Avatar.png') }}" alt="Sabrina - VaryaCode" class="w-36 h-36 md:w-40 md:h-40 object-contain flex-shrink-0">
                <div>
                    <h2 class="font-heading text-3xl sm:text-4xl font-bold mb-6 text-vc-text">La personne derrière le code</h2>
                    <p class="text-vc-text-light text-lg leading-relaxed">
                        Je suis développeuse web en Dordogne. J'accompagne les indépendants, les petites entreprises locales et les associations qui veulent exister en ligne — sans jargon, sans budget démesuré. Un seul interlocuteur, pas d'agence, pas de sous-traitance.
                    </p>
                </div>
            </div>
        </div>
    </section>

    {# ===== SECTION 4 — OFFRES RÉSUMÉ (fond clair) ===== #}
    <section id="offres" class="py-20 bg-vc-bg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="font-heading text-3xl sm:text-4xl font-bold text-center mb-4 text-vc-text" data-animate>
                Une offre pour chaque besoin
            </h2>
            <p class="text-center text-vc-text-muted mb-12" data-animate data-animate-delay="100">Engagement 12 mois ou sans engagement (+10&nbsp;€/mois)</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
                {# Vitrine #}
                <div class="card-v2 flex flex-col" data-animate data-animate-delay="100">
                    <div class="mb-4">
                        <h3 class="font-heading text-xl font-bold text-vc-text">Vitrine</h3>
                        <p class="text-vc-text-muted text-sm mt-1">On vous met en ligne</p>
                    </div>
                    <p class="font-heading text-4xl font-bold text-vc-blue mb-1">35€<span class="text-lg font-medium text-vc-text-muted">/mois</span></p>
                    <ul class="mt-6 space-y-3 text-sm text-vc-text-light flex-grow">
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Site vitrine professionnel</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Hébergement et maintenance inclus</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Optimisé pour Google</li>
                    </ul>
                    <a href="{{ path('app_offers') }}" class="btn-secondary text-center mt-6 !py-3 !text-base">Choisir ce plan</a>
                </div>

                {# Pilote Automatique — RECOMMANDÉ #}
                <div class="card-v2 flex flex-col relative border-vc-blue border-2" data-animate data-animate-delay="200">
                    <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-vc-blue text-white text-xs font-heading font-semibold px-4 py-1 rounded-full">RECOMMANDÉ</span>
                    <div class="mb-4">
                        <h3 class="font-heading text-xl font-bold text-vc-text">Pilote Automatique</h3>
                        <p class="text-vc-text-muted text-sm mt-1">Vos clients réservent en ligne</p>
                    </div>
                    <p class="font-heading text-4xl font-bold text-vc-blue mb-1">55€<span class="text-lg font-medium text-vc-text-muted">/mois</span></p>
                    <ul class="mt-6 space-y-3 text-sm text-vc-text-light flex-grow">
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Tout Vitrine inclus</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Réservation en ligne</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Avis clients intégrés</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Formulaire avancé</li>
                    </ul>
                    <a href="{{ path('app_offers') }}" class="btn-primary text-center mt-6 !py-3 !text-base">Choisir ce plan</a>
                </div>

                {# Décollage #}
                <div class="card-v2 flex flex-col" data-animate data-animate-delay="300">
                    <div class="mb-4">
                        <h3 class="font-heading text-xl font-bold text-vc-text">Décollage</h3>
                        <p class="text-vc-text-muted text-sm mt-1">Votre site travaille pour vous</p>
                    </div>
                    <p class="font-heading text-4xl font-bold text-vc-blue mb-1">75€<span class="text-lg font-medium text-vc-text-muted">/mois</span></p>
                    <ul class="mt-6 space-y-3 text-sm text-vc-text-light flex-grow">
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Tout Pilote Auto inclus</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Blog / actualités</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Fidélisation clients</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Modifications incluses</li>
                    </ul>
                    <a href="{{ path('app_offers') }}" class="btn-secondary text-center mt-6 !py-3 !text-base">Choisir ce plan</a>
                </div>
            </div>
            <div class="text-center" data-animate>
                <a href="{{ path('app_offers') }}" class="text-vc-blue hover:text-vc-blue-royal transition-colors font-medium">
                    Voir le détail des offres &rarr;
                </a>
            </div>
        </div>
    </section>

    {# ===== SECTION 5 — PORTFOLIO LUSgem (fond blanc avec accent) ===== #}
    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="font-heading text-3xl sm:text-4xl font-bold text-center mb-12 text-vc-text" data-animate>
                Un projet, un exemple concret
            </h2>
            <div class="card-v2 !p-0 overflow-hidden" data-animate data-animate-delay="100">
                <div class="grid grid-cols-1 lg:grid-cols-2">
                    <div class="aspect-video lg:aspect-auto bg-slate-100 overflow-hidden">
                        <img src="{{ asset('img/home-lusgem.png') }}" alt="Capture d'écran du site Les Univers Singuliers" class="w-full h-full object-cover">
                    </div>
                    <div class="p-8 lg:p-10 flex flex-col justify-center">
                        <span class="inline-block w-fit px-3 py-1 rounded-full bg-vc-blue/10 text-vc-blue text-xs font-semibold mb-4">Projet client</span>
                        <h3 class="font-heading text-2xl font-bold mb-4 text-vc-text">Les Univers Singuliers (LUSgem)</h3>
                        <p class="text-vc-text-light mb-4">
                            Site complet pour une structure associative locale en Dordogne. Présentation de l'activité, interface d'administration pour gérer les contenus, design sobre et professionnel.
                        </p>
                        <p class="text-vc-text-light mb-6">
                            Un projet livré clé en main, fonctionnel et pensé pour durer.
                        </p>
                        <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                            <p class="text-vc-text-muted text-sm italic">"Témoignage à venir"</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ===== SECTION 6 — MÉTHODE RÉSUMÉE (fond clair) ===== #}
    <section class="py-20 bg-vc-bg">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="font-heading text-3xl sm:text-4xl font-bold text-center mb-12 text-vc-text" data-animate>
                Comment ça se passe&nbsp;?
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
                {% set steps = [
                    { icon: '💬', title: 'On discute', desc: '30 min gratuites pour comprendre votre besoin' },
                    { icon: '🎨', title: 'Je propose', desc: 'Maquette envoyée en 3 à 5 jours' },
                    { icon: '⚡', title: 'Je construis', desc: 'Votre site prend forme en 1 à 2 semaines' },
                    { icon: '🚀', title: "C'est en ligne", desc: 'Mise en ligne le jour J, clé en main' },
                    { icon: '🛡️', title: 'Je gère', desc: 'Maintenance et mises à jour tous les mois' }
                ] %}
                {% for step in steps %}
                <div class="text-center" data-animate data-animate-delay="{{ loop.index * 100 }}">
                    <div class="w-14 h-14 rounded-2xl bg-white border border-slate-200 flex items-center justify-center mx-auto mb-4 text-2xl">
                        {{ step.icon }}
                    </div>
                    <h3 class="font-heading font-semibold text-vc-text mb-2">{{ step.title }}</h3>
                    <p class="text-vc-text-muted text-sm">{{ step.desc }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    {# ===== SECTION 7 — FAQ (fond blanc) ===== #}
    <section class="py-20 bg-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="font-heading text-3xl sm:text-4xl font-bold text-center mb-12 text-vc-text" data-animate>
                Questions fréquentes
            </h2>
            <div class="space-y-4" data-animate data-animate-delay="100">
                {% set faqs = [
                    { q: "Combien coûte un site web ?", a: "Mes formules commencent à 35 €/mois pour un site vitrine professionnel. Le plan Pilote Automatique avec réservation en ligne est à 55 €/mois, et le plan Décollage avec blog et fidélisation est à 75 €/mois. Si vous préférez payer en une fois, c'est possible sur devis." },
                    { q: "Combien de temps faut-il pour avoir mon site ?", a: "En général, votre site est en ligne en 1 à 2 semaines après validation de la maquette. La maquette elle-même est prête en 3 à 5 jours après notre premier échange." },
                    { q: "Je n'y connais rien en technique, c'est un problème ?", a: "Pas du tout — c'est même la majorité de mes clients. Je m'occupe de toute la partie technique. Vous me décrivez votre activité et vos besoins, je fais le reste. Pas de jargon, pas de prise de tête." },
                    { q: "Puis-je changer de plan plus tard ?", a: "Oui, vous pouvez passer à un plan supérieur à tout moment. La différence est ajustée sur votre prochaine facture." },
                    { q: "Que se passe-t-il si j'arrête mon abonnement ?", a: "Votre site vous appartient. Si vous arrêtez, je vous transmets l'intégralité du code source et des contenus. Vous pouvez repartir avec tout et le faire héberger où vous le souhaitez." }
                ] %}
                {% for faq in faqs %}
                <div class="bg-vc-bg rounded-2xl border border-slate-200 overflow-hidden">
                    <button data-accordion-toggle class="w-full flex items-center justify-between p-6 text-left">
                        <span class="font-heading font-semibold text-lg text-vc-text">{{ faq.q }}</span>
                        <svg data-accordion-icon class="w-5 h-5 text-vc-text-muted flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="hidden px-6 pb-6 text-vc-text-light">
                        {{ faq.a }}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    {# ===== SECTION 8 — CTA FINAL (fond sombre) ===== #}
    <section class="py-20 bg-vc-dark">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
            <h2 class="font-heading text-3xl sm:text-4xl font-bold mb-6 text-white">Prêt(e) à exister en ligne&nbsp;?</h2>
            <p class="text-slate-300 text-lg mb-4">
                Décrivez votre projet en quelques clics. Je vous recontacte sous 48h avec une proposition adaptée.
            </p>
            <p class="text-slate-400 text-sm mb-10">
                Votre site vous appartient. Vous pouvez arrêter quand vous voulez et repartir avec tout.
            </p>
            <a href="{{ path('app_decouvrir') }}" class="btn-primary">Lancer mon projet &rarr;</a>
        </div>
    </section>

</div>
{% endblock %}
