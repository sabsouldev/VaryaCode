{% extends 'base.html.twig' %}

{% block title %}Offres — VaryaCode{% endblock %}
{% block meta_description %}Découvrez les offres VaryaCode : sites vitrines dès 35 €/mois. Vitrine, Pilote Automatique ou Décollage — trouvez la formule adaptée à votre activité.{% endblock %}

{% block body %}
<div class="pt-16">

    {# ===== HEADER ===== #}
    <section class="py-16 bg-vc-bg">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="font-heading text-4xl sm:text-5xl font-bold text-vc-text mb-6" data-animate>
                Des offres claires, sans surprise
            </h1>
            <p class="text-vc-text-light text-lg" data-animate data-animate-delay="100">
                Choisissez la formule adaptée à votre activité. Engagement 12 mois ou sans engagement (+10&nbsp;€/mois).
            </p>
        </div>
    </section>

    {# ===== 3 PLANS ABONNEMENT ===== #}
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

                {# Vitrine #}
                <div class="card-v2 flex flex-col" data-animate data-animate-delay="100">
                    <div class="mb-6">
                        <h2 class="font-heading text-2xl font-bold text-vc-text">Vitrine</h2>
                        <p class="text-vc-text-muted mt-1">On vous met en ligne</p>
                    </div>
                    <p class="font-heading text-5xl font-bold text-vc-blue">35€<span class="text-xl font-medium text-vc-text-muted">/mois</span></p>
                    <p class="text-sm text-vc-text-muted mt-1">ou 45 €/mois sans engagement</p>

                    <ul class="mt-8 space-y-4 text-vc-text-light flex-grow">
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Site vitrine professionnel (3-5 pages)</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Design responsive (mobile, tablette, PC)</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Hébergement et nom de domaine inclus</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Maintenance et mises à jour</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Optimisation Google (SEO de base)</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Formulaire de contact</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Certificat SSL (https)</li>
                    </ul>

                    <div class="mt-8 space-y-3">
                        <a href="{{ stripe_vitrine }}" class="btn-secondary ...">Choisir Vitrine — 35€/mois</a>
                        <a href="{{ stripe_vitrine_libre }}" class="btn-secondary ...">Sans engagement — 45€/mois</a>
                    </div>
                </div>

                {# Pilote Automatique — RECOMMANDÉ #}
                <div class="card-v2 flex flex-col relative border-vc-blue border-2" data-animate data-animate-delay="200">
                    <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-vc-blue text-white text-xs font-heading font-semibold px-4 py-1 rounded-full">RECOMMANDÉ</span>
                    <div class="mb-6">
                        <h2 class="font-heading text-2xl font-bold text-vc-text">Pilote Automatique</h2>
                        <p class="text-vc-text-muted mt-1">Vos clients réservent en ligne</p>
                    </div>
                    <p class="font-heading text-5xl font-bold text-vc-blue">55€<span class="text-xl font-medium text-vc-text-muted">/mois</span></p>
                    <p class="text-sm text-vc-text-muted mt-1">ou 65 €/mois sans engagement</p>

                    <ul class="mt-8 space-y-4 text-vc-text-light flex-grow">
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><strong class="text-vc-text">Tout ce qui est dans Vitrine</strong></li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Système de réservation en ligne</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Intégration avis clients (Google / collectés)</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Formulaire avancé (multi-étapes, fichier joint)</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Carte interactive (Google Maps)</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Galerie photo</li>
                    </ul>

                    <div class="mt-8 space-y-3">
                        <a href="{{ stripe_pilote }}" class="btn-primary ...">Choisir Pilote Auto — 55€/mois</a>
                        <a href="{{ stripe_pilote_libre }}" class="btn-secondary ...">Sans engagement — 65€/mois</a>
                    </div>
                </div>

                {# Décollage #}
                <div class="card-v2 flex flex-col" data-animate data-animate-delay="300">
                    <div class="mb-6">
                        <h2 class="font-heading text-2xl font-bold text-vc-text">Décollage</h2>
                        <p class="text-vc-text-muted mt-1">Votre site travaille pour vous</p>
                    </div>
                    <p class="font-heading text-5xl font-bold text-vc-blue">75€<span class="text-xl font-medium text-vc-text-muted">/mois</span></p>
                    <p class="text-sm text-vc-text-muted mt-1">ou 85 €/mois sans engagement</p>

                    <ul class="mt-8 space-y-4 text-vc-text-light flex-grow">
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><strong class="text-vc-text">Tout ce qui est dans Pilote Auto</strong></li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Blog / espace actualités</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Programme de fidélisation clients</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Modifications de contenu incluses (1h/mois)</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Rapport mensuel de performance</li>
                        <li class="flex items-start gap-3"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Support prioritaire</li>
                    </ul>

                    <div class="mt-8 space-y-3">
                        <a href="{{ stripe_decollage }}" class="btn-secondary ...">Choisir Décollage — 75€/mois</a>
                        <a href="{{ stripe_decollage_libre }}" class="btn-secondary ...">Sans engagement — 85€/mois</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ===== ONE-SHOT + MAINTENANCE ===== #}
    <section class="py-16 bg-vc-bg">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                {# One-shot #}
                <div class="card-v2" data-animate>
                    <h3 class="font-heading text-xl font-bold text-vc-text mb-2">Projet sur devis (one-shot)</h3>
                    <p class="text-vc-text-muted text-sm mb-4">Pour ceux qui préfèrent payer en une fois</p>
                    <p class="font-heading text-3xl font-bold text-vc-text mb-4">800 — 2&nbsp;500€</p>
                    <p class="text-vc-text-light mb-6">
                        Vous recevez votre site clé en main avec le code source. Idéal si vous avez votre propre hébergement ou si vous préférez un paiement unique.
                    </p>
                    <a href="{{ path('app_contact') }}" class="text-vc-blue hover:text-vc-blue-royal font-medium transition-colors">Demander un devis &rarr;</a>
                </div>

                {# Maintenance #}
                <div class="card-v2" data-animate data-animate-delay="100">
                    <h3 class="font-heading text-xl font-bold text-vc-text mb-2">Maintenance essentielle</h3>
                    <p class="text-vc-text-muted text-sm mb-4">Pour les clients one-shot</p>
                    <p class="font-heading text-3xl font-bold text-vc-text mb-1">19€<span class="text-lg font-medium text-vc-text-muted">/mois</span></p>
                    <ul class="mt-4 space-y-3 text-sm text-vc-text-light mb-6">
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Mises à jour de sécurité</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Sauvegardes régulières</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Monitoring et disponibilité</li>
                        <li class="flex items-start gap-2"><svg class="w-5 h-5 text-vc-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Support par email</li>
                    </ul>
                    <a href="{{ stripe_maintenance }}" class="text-vc-blue ...">S'abonner — 19€/mois →</a>
                </div>
            </div>
        </div>
    </section>

    {# ===== GARANTIE ===== #}
    <section class="py-16 bg-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
            <div class="w-16 h-16 rounded-2xl bg-vc-mint/10 flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-vc-mint" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h2 class="font-heading text-2xl font-bold text-vc-text mb-4">Votre site vous appartient</h2>
            <p class="text-vc-text-light text-lg">
                Si vous arrêtez votre abonnement, je vous transmets l'intégralité du code source, des contenus et des accès. Vous repartez avec tout, sans frais supplémentaires.
            </p>
        </div>
    </section>

    {# ===== CTA ===== #}
    <section class="py-16 bg-vc-dark">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
            <h2 class="font-heading text-3xl font-bold text-white mb-4">Vous ne savez pas quel plan choisir&nbsp;?</h2>
            <p class="text-slate-300 mb-8">Répondez à 4 questions simples et je vous recommande la formule adaptée à votre activité.</p>
            <a href="{{ path('app_decouvrir') }}" class="btn-primary">Quel plan pour moi&nbsp;? &rarr;</a>
        </div>
    </section>

</div>
{% endblock %}
