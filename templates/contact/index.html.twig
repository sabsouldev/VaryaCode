{% extends 'base.html.twig' %}

{% block title %}Contact — VaryaCode{% endblock %}
{% block meta_description %}Contactez VaryaCode pour votre projet web. Réponse sous 48h.{% endblock %}

{% block body %}
<div class="pt-16">

    {# ===== INTRODUCTION ===== #}
    <section class="py-20 bg-vc-bg">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="font-heading text-4xl sm:text-5xl font-bold text-vc-text mb-6" data-animate>Parlons de votre projet</h1>
            <p class="text-vc-text-light text-lg leading-relaxed" data-animate data-animate-delay="100">
                Vous avez une idée, un besoin, une question&nbsp;? Écrivez-moi directement ci-dessous. Je vous recontacte sous 48h.
            </p>
            <div class="mt-6" data-animate data-animate-delay="200">
                <a href="{{ path('app_decouvrir') }}" class="text-vc-blue hover:text-vc-blue-royal font-medium transition-colors">Ou découvrez quel plan est fait pour vous &rarr;</a>
            </div>
        </div>
    </section>

    {# ===== CONTACT ===== #}
    <section class="py-16 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {# Infos #}
                <div data-animate>
                    <h2 class="font-heading text-2xl font-bold text-vc-text mb-6">Envie d'échanger directement&nbsp;?</h2>
                    <ul class="space-y-4">
                        <li class="flex items-center gap-3">
                            <svg class="w-5 h-5 text-vc-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            <a href="mailto:contact@varyacode.fr" class="text-vc-text-light hover:text-vc-blue transition-colors">contact@varyacode.fr</a>
                        </li>
                        <li class="flex items-center gap-3">
                            <svg class="w-5 h-5 text-vc-blue-sky flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            <span class="text-vc-text-light">Basée en Dordogne — je travaille avec toute la France.</span>
                        </li>
                    </ul>
                </div>

                {# Formulaire #}
                <div id="contact" data-animate data-animate-delay="100">
                    {% if contact_success is defined and contact_success %}
                    <div class="bg-vc-mint/10 border border-vc-mint/20 rounded-xl p-4 mb-6">
                        <p class="text-vc-mint font-medium">Merci pour votre message&nbsp;! Je vous réponds sous 48h.</p>
                    </div>
                    {% endif %}

                    <form method="post" action="{{ path('app_contact_submit') }}" class="space-y-4">
                        <div>
                            <label for="contact_name" class="block text-sm font-medium text-vc-text mb-2">Votre nom <span class="text-red-500">*</span></label>
                            <input type="text" id="contact_name" name="contact_name" required class="w-full border border-slate-300 rounded-xl px-4 py-3 text-vc-text placeholder-vc-text-muted focus:outline-none focus:border-vc-blue focus:ring-1 focus:ring-vc-blue transition-colors">
                        </div>
                        <div>
                            <label for="contact_email" class="block text-sm font-medium text-vc-text mb-2">Votre email <span class="text-red-500">*</span></label>
                            <input type="email" id="contact_email" name="contact_email" required class="w-full border border-slate-300 rounded-xl px-4 py-3 text-vc-text placeholder-vc-text-muted focus:outline-none focus:border-vc-blue focus:ring-1 focus:ring-vc-blue transition-colors">
                        </div>
                        <div>
                            <label for="contact_subject" class="block text-sm font-medium text-vc-text mb-2">Sujet <span class="text-red-500">*</span></label>
                            <select id="contact_subject" name="contact_subject" required class="w-full border border-slate-300 rounded-xl px-4 py-3 text-vc-text focus:outline-none focus:border-vc-blue focus:ring-1 focus:ring-vc-blue transition-colors">
                                <option value="">Choisissez un sujet</option>
                                <option value="Question sur une offre">Question sur une offre</option>
                                <option value="Demande de renseignement">Demande de renseignement</option>
                                <option value="Partenariat / collaboration">Partenariat / collaboration</option>
                                <option value="Autre">Autre</option>
                            </select>
                        </div>
                        <div>
                            <label for="contact_message" class="block text-sm font-medium text-vc-text mb-2">Votre message <span class="text-red-500">*</span></label>
                            <textarea id="contact_message" name="contact_message" required rows="5" class="w-full border border-slate-300 rounded-xl px-4 py-3 text-vc-text placeholder-vc-text-muted focus:outline-none focus:border-vc-blue focus:ring-1 focus:ring-vc-blue transition-colors"></textarea>
                        </div>
                        <button type="submit" class="btn-primary !py-3 w-full text-center">Envoyer</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    {# ===== FAQ ===== #}
    <section class="py-16 bg-vc-bg">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="font-heading text-2xl font-bold text-center text-vc-text mb-10" data-animate>Questions fréquentes</h2>
            <div class="space-y-4" data-animate data-animate-delay="100">
                {% set faq = [
                    { q: 'Vous travaillez uniquement en Dordogne ?', a: 'Je suis basée en Dordogne, mais je travaille avec des clients partout en France. Tout se fait en ligne — visio, email, téléphone.' },
                    { q: 'Quel est le délai pour recevoir une réponse ?', a: 'Je m\'engage à vous recontacter sous 48h maximum après réception de votre demande.' },
                    { q: 'Je ne sais pas du tout ce qu\'il me faut, c\'est grave ?', a: 'Pas du tout ! Répondez au questionnaire en 2 minutes ou écrivez-moi, et on en discute ensemble.' }
                ] %}
                {% for item in faq %}
                <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
                    <button data-accordion-toggle class="w-full flex items-center justify-between p-6 text-left">
                        <span class="font-heading font-semibold text-vc-text">{{ item.q }}</span>
                        <svg data-accordion-icon class="w-5 h-5 text-vc-text-muted flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="hidden px-6 pb-6 text-vc-text-light">{{ item.a }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

</div>
{% endblock %}
