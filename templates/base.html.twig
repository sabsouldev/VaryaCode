<!DOCTYPE html>
<html lang="fr">
    <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}VaryaCode — Sites web pour petites structures{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}VaryaCode, développeuse web en Dordogne. Sites vitrines professionnels dès 35 €/mois pour artisans, associations et indépendants.{% endblock %}">

    {# Favicons #}
    <link rel="icon" type="image/x-icon" href="{{ asset('img/favicon.ico') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('img/favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('img/favicon-16x16.png') }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('img/apple-touch-icon.png') }}">
    <link rel="manifest" href="{{ asset('img/site.webmanifest') }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
    <body class="bg-vc-bg text-vc-text font-body antialiased">
        {# Navbar #}
        {% include 'components/_navbar.html.twig' %}

        {# Main content #}
        <main>
            {% block body %}{% endblock %}
        </main>

        {# Footer #}
        {% include 'components/_footer.html.twig' %}
    </body>
</html>
